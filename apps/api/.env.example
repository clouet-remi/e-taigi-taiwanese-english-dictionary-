# Neon pooled connection for application runtime
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-west-3.aws.neon.tech/neondb?sslmode=require"

# Neon direct connection for Prisma CLI / migrations
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.eu-west-3.aws.neon.tech/neondb?sslmode=require"

# Local dev port. On Vercel this is managed by the platform.
PORT=4000

# Local frontend + deployed frontend
CORS_ORIGIN="http://localhost:3000,http://localhost:3003,https://your-frontend.vercel.app"

# false locally, true behind a proxy/platform such as Vercel or Render
TRUST_PROXY=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
