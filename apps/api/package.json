{
  "name": "taiwanese-dictionary-api",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "prisma generate && esbuild src/handler.ts --bundle --platform=node --format=esm --outfile=api/index.js --external:@prisma/client",
    "dev": "tsx src/index.ts",
    "test": "node --import tsx --test test/all.test.ts",
    "test:watch": "node --import tsx --test --watch test/all.test.ts",
    "audio:download": "tsx scripts/download-audio-backups.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "zod": "^4.0.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "prisma": "^6.19.2",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
